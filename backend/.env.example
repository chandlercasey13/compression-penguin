# AWS region
AWS_REGION=us-east-1

# S3 bucket name (must already exist)
S3_BUCKET=conversion-penguin-YOURACCOUNTID

# DynamoDB table name (must already exist)
JOBS_TABLE=ConversionPenguinJobs

# Name of the convert Lambda function (used by create-job handler)
CONVERT_FUNCTION_NAME=conversion-penguin-ConvertFunction

# CORS origin (use * for dev, restrict in production)
ALLOWED_ORIGIN=*
